<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Structural Type"
        Height="200" Width="350"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="10">
        <TextBlock Text="Select Family:" Margin="0,0,0,5"/>
        <ComboBox x:Name="familyBox" Height="25" Margin="0,0,0,10"/>

        <TextBlock Text="Select Type:" Margin="0,0,0,5"/>
        <ComboBox x:Name="typeBox" Height="25" Margin="0,0,0,10"/>

        <Button x:Name="okButton" Content="OK" Height="30" Width="80" HorizontalAlignment="Right"/>
    </StackPanel>
</Window>